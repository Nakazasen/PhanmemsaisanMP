# Python cache
__pycache__/
*.py[cod]
*$py.class

# Database
data/
*.db

# Excel files (Source data & Generated reports)
# We exclude them to keep the repo clean and avoid pushing company confidential data
*.xlsx
*.xls
!FORM.xlsx

# Keep generated Excel files ignored by default, but track requirement source workbooks.
!raw/requirements/
!raw/requirements/*.xlsx

# System files
.DS_Store
Thumbs.db

# PyInstaller & Build
build/
dist/
*.spec

# ABW runtime noise (safe to regenerate)
.brain/used_nonces.json
.brain/route_log.jsonl
.brain/acceptance_log.jsonl
.brain/acceptance_requests/
.brain/runner_artifacts/
.brain/cache/
.brain/tmp/
.brain/*.log
drafts/*.tmp
